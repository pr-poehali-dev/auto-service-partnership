{
  "tests": [
    {
      "name": "Unauthorized orders request",
      "method": "GET",
      "path": "/?action=orders",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Unauthorized admin leads request",
      "method": "GET",
      "path": "/?action=admin-leads",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Wrong admin password login",
      "method": "POST",
      "path": "/?action=admin-login",
      "body": {"password": "wrong_password_test"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Submit lead missing fields",
      "method": "POST",
      "path": "/?action=submit-lead",
      "body": {"name": "", "phone": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Submit lead valid",
      "method": "POST",
      "path": "/?action=submit-lead",
      "body": {"name": "Пётр Тестов", "phone": "+79135559912", "service": "ОСАГО", "comment": "Тест"},
      "expectedStatus": 200
    }
  ]
}